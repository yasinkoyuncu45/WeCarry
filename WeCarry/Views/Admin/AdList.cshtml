@model IEnumerable<WeCarry.Models.MVVM.Ads>
@{
    ViewData["Title"] = "AdList";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-table me-1"></i>
        İlan Listesi
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="datatablesSimple" class="table table-bordered table-sm align-middle">
                <thead class="table-light small">
                    <tr>
                        <th>ID</th>
                        <th>Sahibi</th>
                        <th>Hizmet</th>
                        <th>Çıkış</th>
                        <th>Varış</th>
                        <th>KM</th>
                        <th class="d-none d-lg-table-cell">Açıklama</th>
                        <th>Durum</th>
                        <th class="d-none d-md-table-cell">Tarih</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ad in Model)
                    {
                        <tr>
                            <td>@ad.AdsID</td>
                            <td>@($"{ad.User?.Name} {ad.User?.Surname}")</td>
                            <td>
                                @if (ad.ServiceType?.Name == "TruckService")
                                {
                                    <span class="badge bg-primary">Tır Hizmeti</span>
                                }
                                else if (ad.ServiceType?.Name == "TowTruckService")
                                {
                                    <span class="badge bg-warning text-dark">Çekici Hizmeti</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Kullanıcı</span>
                                }
                            </td>
                            <td>@ad.FoundCity</td>
                            <td>@ad.DestinationCity</td>

                            <td class="d-none d-md-table-cell">@ad.KmFee</td>
                            <td class="d-none d-lg-table-cell">@ad.AdvertisementText</td>

                            <td>
                                @if (ad.IsActive)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pasif</span>
                                }
                            </td>
                            <td class="d-none d-md-table-cell">@ad.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-nowrap">
                                <a asp-controller="Admin" asp-action="EditAd" asp-route-id="@ad.AdsID"
                                   class="btn btn-sm btn-primary">Düzenle</a>
                                <form asp-controller="Admin" asp-action="DeleteAd" asp-route-id="@ad.AdsID"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Bu ilanı silmek istediğinize emin misiniz?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
