@model WeCarry.Models.MVVM.Ads
@{
    ViewData["Title"] = "İlan Düzenle";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header">
        <i class="fas fa-edit me-1"></i> İlan Düzenle
    </div>
    <div class="card-body">
        <form asp-action="EditAd" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AdsID" />
            <input type="hidden" asp-for="UserID" />
            <input type="hidden" asp-for="ServiceTypeID" />


            <div class="mb-3">
                <label class="form-label">İlan Sahibi</label>
                <input class="form-control" value="@($"{Model.User?.Name} {Model.User?.Surname}")" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label">Hizmet Türü</label>
                @if (Model.ServiceType?.Name == "TruckService")
                {
                    <input class="form-control" value="Tır Hizmeti" readonly />
                }
                else if (Model.ServiceType?.Name == "TowTruckService")
                {
                    <input class="form-control" value="Çekici Hizmeti" readonly />
                }
                else
                {
                    <input class="form-control" value="Kullanıcı" readonly />
                }
            </div>

            <div class="mb-3">
                <label asp-for="FoundCity" class="form-label"></label>
                <input asp-for="FoundCity" class="form-control" />
                <span asp-validation-for="FoundCity" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DestinationCity" class="form-label"></label>
                <input asp-for="DestinationCity" class="form-control" />
                <span asp-validation-for="DestinationCity" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="KmFee" class="form-label"></label>
                <input asp-for="KmFee" class="form-control" />
                <span asp-validation-for="KmFee" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="AdvertisementText" class="form-label"></label>
                <textarea asp-for="AdvertisementText" class="form-control" rows="3"></textarea>
                <span asp-validation-for="AdvertisementText" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>

            <div class="text-end">
                <a asp-action="AdList" class="btn btn-secondary">İptal</a>
                <button type="submit" class="btn btn-primary">Kaydet</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
