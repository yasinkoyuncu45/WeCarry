@model IEnumerable<WeCarry.Models.MVVM.User>
@{
    ViewData["Title"] = "UserList";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}
<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-table me-1"></i>
        Kullanıcı Listesi
    </div>
    <div class="card-body">
        <table id="datatablesSimple">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.UserID)</th>
                    <th>@Html.DisplayNameFor(model => model.Name)</th>
                    <th>@Html.DisplayNameFor(model => model.Surname)</th>
                    <th>@Html.DisplayNameFor(model => model.Email)</th>
                    <th>@Html.DisplayNameFor(model => model.Telephone)</th>
                    <th>@Html.DisplayNameFor(model => model.Address)</th>
                    <th>@Html.DisplayNameFor(model => model.Firm)</th>
                    <th>@Html.DisplayNameFor(model => model.UserTypeID)</th>
                    <th>@Html.DisplayNameFor(model => model.ServiceTypeID)</th>
                    <th>@Html.DisplayNameFor(model => model.Active)</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.UserID</td>
                        <td>@user.Name</td>
                        <td>@user.Surname</td>
                        <td>@user.Email</td>
                        <td>@user.Telephone</td>
                        <td>@user.Address</td>
                        <td>@user.Firm</td>
                        <td>
                            @user.UserTypeID
                            (
                            @{
                                string typeText = user.UserTypeID switch
                                {
                                    1 => "Admin",
                                    2 => "Tır Sürücüsü",
                                    3 => "Çekici Sürücüsü",
                                    4 => "Kullanıcı",
                                    _ => "Bilinmiyor"
                                };
                            }
                            @typeText
                            )
                        </td>
                        <td>
                            @user.ServiceTypeID
                            (
                            @{
                                string serviceText = user.ServiceTypeID switch
                                {
                                    1 => "Tır",
                                    2 => "Çekici",
                                    3 => "Kullanıcı",
                                    _ => "Bilinmiyor"
                                };
                            }
                            @serviceText
                            )
                        </td>
                        <td>
                            @if (user.Active)
                            {
                                <span class="badge bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Pasif</span>
                            }
                        </td>
                        <td class="text-nowrap">
                            <a asp-controller="Admin" asp-action="EditUser" asp-route-id="@user.UserID"
                               class="btn btn-sm btn-primary">Düzenle</a>
                            <form asp-controller="Admin" asp-action="DeleteUser" asp-route-id="@user.UserID"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Bu kullanıcıyı silmek istediğinize emin misiniz?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>


        </table>
    </div>
</div>