@model IEnumerable<WeCarry.Models.MVVM.ConversationListItemVm>
@{
    ViewData["Title"] = "Konuşmalar";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-comments me-1"></i> Konuşmalar
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover table-sm align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>İlan</th>
                        <th>Başlatan</th>
                        <th>İlan Sahibi</th>
                        <th>Başlama Zamanı</th>
                        <th>Bitiş Zamanı</th>
                        <th>Durum</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ConversationID</td>
                                <td>
                                    <div class="small text-muted">ID: @item.AdID</div>
                                    <div>@item.AdID</div>
                                </td>
                                <td>@item.StarterUserName</td>
                                <td>@item.OwnerUserName</td>
                                <td>@item.CreatedAt</td>
                                <td>@(item.EndedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                <td>
                                    @if (item.EndedAt != null)
                                    {
                                        <span class="badge bg-secondary">Sonlandırılmış</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-primary"
                                       asp-controller="Admin"
                                       asp-action="ConversationDetail"
                                       asp-route-id="@item.ConversationID">
                                        Detay
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">Hiç konuşma bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
