@model WeCarry.Models.MVVM.User
@{
    ViewData["Title"] = "Kullanıcı Düzenle";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="card">
    <div class="card-header">Kullanıcı Düzenle</div>
    <div class="card-body">
        <form asp-action="EditUser" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserID" />

            <!-- Toplu hata özeti -->
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Surname" class="form-label"></label>
                    <input asp-for="Surname" class="form-control" />
                    <span asp-validation-for="Surname" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Telephone" class="form-label"></label>
                    <input asp-for="Telephone" class="form-control" />
                    <span asp-validation-for="Telephone" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Address" class="form-label"></label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Firm" class="form-label"></label>
                    <input asp-for="Firm" class="form-control" />
                    <span asp-validation-for="Firm" class="text-danger"></span>
                </div>

                <!-- İstersen bunları input bırakabilir ya da dropdown yapabilirsin -->
                <div class="col-md-3">
                    <label asp-for="UserTypeID" class="form-label"></label>
                    <input asp-for="UserTypeID" class="form-control" />
                    <span asp-validation-for="UserTypeID" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="ServiceTypeID" class="form-label"></label>
                    <input asp-for="ServiceTypeID" class="form-control" />
                    <span asp-validation-for="ServiceTypeID" class="text-danger"></span>
                </div>

                <div class="col-12 form-check mt-2">
                    <input class="form-check-input" asp-for="Active" id="ActiveChk" />
                    <label class="form-check-label" for="ActiveChk">Aktif</label>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a asp-action="UserList" class="btn btn-secondary">Geri</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
