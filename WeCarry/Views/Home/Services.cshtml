@{
    ViewData["Title"] = "Hizmetlerimiz";
    Layout = "~/Views/Shared/DefaultLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/services.css" asp-append-version="true" />
}


<section class="py-5 bg-light">
    <div class="container px-5 text-center">
        <h1 class="display-5 fw-bolder">Hizmetlerimiz</h1>
        <p class="lead mb-0">Taşıyıcı firmalar ile müşterileri aynı platformda buluşturuyoruz</p>
    </div>
</section>

<!-- Tanıtım bölümü -->
<section class="py-5 bg-light">
    <div class="container px-5 my-5">
        <div class="row gx-5 align-items-center">
            <div class="col-lg-6">
                <h2 class="fw-bolder">Taşıyıcın.com Nasıl Çalışır?</h2>
                <p class="lead mb-4">
                    Taşıyıcın.com; tır ve çekici firmalarının ilanlarını yayınladığı,
                    yük sahipleriyle buluşturduğu modern bir taşıma platformudur.
                    Müşteriler kolayca ilanları inceleyebilir, ihtiyaçlarına uygun
                    taşıyıcılarla hızlıca iletişime geçebilir.
                </p>
            </div>
            <div class="col-lg-6 text-center">
                <img class="img-fluid rounded shadow" src="~/resimler/hizmetilk.png" alt="Taşıyıcın.com" loading="lazy" />
            </div>
        </div>
    </div>
</section>

<!-- 3 adımlı ikonlu anlatım -->
<section class="py-5">
    <div class="container px-5 my-5">
        <div class="row gx-5 text-center steps">
            <!-- 1. Adım -->
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0">
                    <div class="card-body">
                        <div class="mb-3">
                            <i class="bi bi-megaphone fs-1 text-primary"></i>
                        </div>
                        <h5 class="fw-bolder">1. İlan Ver</h5>
                        <p class="mb-0">
                            Tır ve çekici firmaları ücretsiz olarak ilanlarını sisteme ekler.
                            Çıkış–varış, fiyat ve diğer detaylar kolayca belirtilir.
                        </p>
                    </div>
                </div>
            </div>
            <!-- 2. Adım -->
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0">
                    <div class="card-body">
                        <div class="mb-3">
                            <i class="bi bi-search fs-1 text-success"></i>
                        </div>
                        <h5 class="fw-bolder">2. İlan Bul</h5>
                        <p class="mb-0">
                            Müşteriler filtreler ile ihtiyaçlarına uygun ilanları görüntüler.
                            Şehir, hizmet türü veya fiyata göre arama yapılabilir.
                        </p>
                    </div>
                </div>
            </div>
            <!-- 3. Adım -->
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0">
                    <div class="card-body">
                        <div class="mb-3">
                            <i class="bi bi-chat-dots fs-1 text-warning"></i>
                        </div>
                        <h5 class="fw-bolder">3. İletişime Geç</h5>
                        <p class="mb-0">
                            Müşteri ve taşıyıcı ilan üzerinden kolayca bağlantı kurar.
                            Böylece doğru hizmet sağlayıcıya hızlıca ulaşılır.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hizmetler kartları -->
        <div class="row gx-5 gy-5 mt-2">
            <!-- Tır İlanları -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 shadow border-0 services-card">
                    <div class="card-img-wrap">
                        <img src="~/resimler/hizmettir.png" alt="Tır İlanları" loading="lazy" />
                    </div>
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Tır İlanları</h5>
                        <p class="card-text mb-0">
                            Tır firmaları uzun yol ve şehirler arası taşımacılık ilanlarını yayınlar.
                            Yük sahipleri ilanları inceleyerek en uygun taşıyıcıyı seçebilir.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Çekici İlanları -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 shadow border-0 services-card">
                    <div class="card-img-wrap">
                        <img src="~/resimler/hizmetcekici.png" alt="Çekici İlanları" loading="lazy" />
                    </div>
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Çekici İlanları</h5>
                        <p class="card-text mb-0">
                            Çekici ihtiyacı olan müşteriler, platformdaki ilanlar sayesinde
                            en yakın ve uygun hizmet sağlayıcısını kolayca bulabilir.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Parsiyel Yük İlanları -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 shadow border-0 services-card">
                    <div class="card-img-wrap">
                        <img src="~/resimler/hizmetparsiyal.png" alt="Parsiyel Yük" loading="lazy" />
                    </div>
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Parsiyel Yük İlanları</h5>
                        <p class="card-text mb-0">
                            Küçük ölçekli yükler için parsiyel taşımacılık ilanları yayınlanır.
                            Böylece daha ekonomik ve pratik çözümler bulunabilir.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Şehirler Arası İlanlar -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 shadow border-0 services-card">
                    <div class="card-img-wrap">
                        <img src="~/resimler/hizmetsehirlerarasi.png" alt="Şehirler Arası" loading="lazy" />
                    </div>
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Şehirler Arası İlanlar</h5>
                        <p class="card-text mb-0">
                            Türkiye’nin dört bir yanında şehirler arası taşımacılık ilanları mevcuttur.
                            İhtiyacınıza uygun olanı seçip hızlıca taşıyıcıyla iletişim kurabilirsiniz.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Acil & Ekspres İlanlar -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 shadow border-0 services-card">
                    <div class="card-img-wrap">
                        <img src="~/resimler/hizmetexpress.png" alt="Acil & Ekspres" loading="lazy" />
                    </div>
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Acil & Ekspres İlanlar</h5>
                        <p class="card-text mb-0">
                            Acil gönderiler için açılan ilanlar sayesinde zaman kaybetmeden
                            uygun taşıyıcıya ulaşabilirsiniz.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Platform Avantajı -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 shadow border-0 services-card">
                    <div class="card-img-wrap">
                        <img src="~/resimler/hizmetplatform.png" alt="Platform Avantajı" loading="lazy" />
                    </div>
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Platform Avantajı</h5>
                        <p class="card-text mb-0">
                            Taşıyıcın.com, taşıyıcılarla müşterileri güvenli bir ortamda
                            bir araya getiren bir çözümdür. Filtreleme seçenekleriyle aradığınızı kolayca bulabilirsiniz.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
