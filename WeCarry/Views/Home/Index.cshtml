@model WeCarry.Models.MVVM.MainPageModel
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/DefaultLayout.cshtml";
}

<!-- Header-->
<header class="bg-dark py-5">
    <div class="container px-5">
        <div class="row gx-5 align-items-center justify-content-center">
            <div class="col-lg-8 col-xl-7 col-xxl-6">
                <div class="my-5 text-center text-xl-start">
                    <h1 class="display-5 fw-bolder text-white mb-2">
                        Yükleriniz Yolda Kalmasın. Doğru Tır ve Çekiciye Anında Ulaşın!
                        Şimdi kaydolun ve farkı yaşayın!
                    </h1>

                    @if (Context.Session.GetInt32("UserId") == null)
                    {
                        <div class="d-grid gap-3 d-sm-flex justify-content-sm-center justify-content-xl-start">
                            <!-- ✅ Taşıyıcı ve Müşteri kayıt sayfaları artık AccountController’da -->
                            <a class="btn btn-primary btn-lg px-4 me-sm-3" href="/Account/CarrierRegistration">Taşıyıcı Ol</a>
                            <a class="btn btn-outline-light btn-lg px-4" href="/Account/Register">Müşteri Ol</a>
                        </div>
                    }
                </div>
            </div>
            <div class="col-xl-5 col-xxl-6 d-none d-xl-block text-center">
                <img src="~/resimler/site-anasayfa.jpg" />
            </div>
        </div>
</header>
<!-- Features section-->
<section class="py-5" id="features">
    <div class="container px-5 my-5">
        <div class="row gx-5">
            <div class="col-lg-4 mb-5 mb-lg-0"><h2 class="fw-bolder mb-0">Neden taşıyıcın'ı Seçmelisiniz ?</h2></div>
            <div class="col-lg-8">
                <div class="row gx-5 row-cols-1 row-cols-md-2">
                    <div class="col mb-5 h-100">
                        <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-collection"></i></div>
                        <h2 class="h5">Çeşitli Hizmetler</h2>
                        <p class="mb-0">Küçük teslimatlardan büyük ölçekli taşıma ve çekmeye kadar, çeşitli ihtiyaçlarınızı karşılamak için eksiksiz bir hizmet yelpazesi sunuyoruz.   </p>
                    </div>
                    <div class="col mb-5 h-100">
                        <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-building"></i></div>
                        <h2 class="h5">Hızlı Eşleştirme</h2>
                        <p class="mb-0">Akıllı platformumuz aracılığıyla ihtiyaçlarınıza en uygun sürücüyü anında bulun, değerli zamanınızdan tasarruf edin.</p>
                    </div>
                    <div class="col mb-5 mb-md-0 h-100">
                        <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-toggles2"></i></div>
                        <h2 class="h5">Çoklu Teklif</h2>
                        <p class="mb-0">Birden fazla sürücüden gerçek zamanlı teklif yanıtları alın, böylece fiyatları ve hizmetleri hızla karşılaştırabilir, zamandan tasarruf edebilir ve şeffaflığı sağlayabilirsiniz. </p>
                    </div>
                    <div class="col h-100">
                        <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-toggles2"></i></div>
                        <h2 class="h5">Serbest Seçim</h2>
                        <p class="mb-0">Her sürücünün geçmiş puanlarını kolayca karşılaştırabilir, bütçenize ve güven kriterlerinize en uygun sürücüyü seçebilirsiniz. </p>
                    </div>
                    <div class="col h-100">
                        <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-toggles2"></i></div>
                        <h2 class="h5">Şeffaf Fiyatlandırma</h2>
                        <p class="mb-0">Tüm hizmet bedelleri kamuya açık ve şeffaftır, önceden fiyat teklifi verilir ve gizli ücretler yoktur, bu nedenle hizmetlerimizi güvenle kullanabilirsiniz.</p>
                    </div>
                    <div class="col h-100">
                        <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-toggles2"></i></div>
                        <h2 class="h5">Güvenli ve Güvenilir</h2>
                        <p class="mb-0">Tam yolculuk takibi ve kullanıcı puanlama sistemimizle eşyalarınızın ve seyahatlerinizin güvenliğini sağlıyor. </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Blog preview section-->
<section class="py-5">
    <div class="container px-5 my-5">
        <div class="row gx-5">

            <!-- SOL / FİLTRE -->
            <div class="col-12 col-lg-3 mb-4">
                <aside class="filter-sidebar">
                    <div class="card shadow-sm border-0 filter-card">
                        <div class="filter-card-header">
                            <i class="bi bi-funnel"></i> Filtrele
                        </div>

                        <div class="card-body">
                            <form method="get" id="filterForm" action="/Home/Index" class="row g-3">
                                <!-- Hizmet Türü -->
                                <div class="col-12">
                                    <label for="serviceSelect" class="form-label">Hizmet Türü</label>
                                    <select id="serviceSelect" name="service" class="form-select">
                                        <option value="">Tümü</option>
                                        <option value="Truck">Tır</option>
                                        <option value="Tow">Çekici</option>
                                    </select>
                                </div>

                                <div id="groupFromTo" class="col-12">
                                    <div class="mb-3">
                                        <label class="form-label">Çıkış Şehir</label>
                                        <select name="from" class="form-select" asp-items="@(new SelectList(Model.CityList, "Name", "Name"))">
                                            <option value="">Seçiniz</option>
                                        </select>
                                    </div>


                                    <div>
                                        <label class="form-label">Varış Şehir</label>
                                        <select name="to" class="form-select" asp-items="@(new SelectList(Model.CityList, "Name", "Name"))">
                                            <option value="">Seçiniz</option>
                                        </select>
                                    </div>
                                </div>

                                <!-- ÇEKİCİ: Tek Şehir -->
                                <div id="groupSingleCity" class="col-12">
                                    <label class="form-label">Şehir</label>
                                    <select name="city" class="form-select" asp-items="@(new SelectList(Model.CityList, "Name", "Name"))">
                                        <option value="">Seçiniz</option>
                                    </select>
                                </div>


                                <div class="col-12 d-grid">
                                    <button class="btn btn-primary" type="submit">
                                        <i class="bi bi-search me-1"></i> Uygula
                                    </button>
                                </div>
                                <div class="col-12 d-grid">
                                    <button class="btn btn-outline-secondary" type="reset" id="btnResetFilters">
                                        Temizle
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </aside>
            </div>




            <!-- SAĞ / İLANLAR -->
            <div class="col-12 col-lg-9">
                <div class="row gx-5 justify-content-center">
                    <div class="col-lg-8 col-xl-6">
                        <div class="text-center">
                            <h2 class="fw-bolder">Tır ve Çekici Hizmetleri</h2>
                            <p class="lead fw-normal text-muted mb-5">Aktif ilanlara bak. Sana uygun hizmeti anında bul...</p>
                        </div>
                    </div>
                </div>

                <div id="adsList">
                    @Html.Partial("_AdsPartial", Model.Ads)
                </div>
                <!-- Eklediklerimiz -->
                <div id="infiniteSentinel" class="text-center my-4" aria-hidden="true">
                    <div id="loadingSpinner" class="spinner-border text-primary" style="display:none;"></div>
                </div>
            </div>
        </div>
    </div>
</section>
<script>
    // --- 1. Filtre Görünürlük Yönetimi ---
    (function () {
        const serviceSel = document.getElementById('serviceSelect');
        const grpFromTo = document.getElementById('groupFromTo');
        const grpSingle = document.getElementById('groupSingleCity');

        function setEnabled(container, enabled) {
            container.querySelectorAll('input, select, textarea, button').forEach(el => {
                el.disabled = !enabled;
            });
        }

        function applyVisibility() {
            const val = (serviceSel.value || '').toLowerCase();

            if (val === 'truck') {
                grpFromTo.style.display = '';
                grpSingle.style.display = 'none';
                setEnabled(grpFromTo, true);
                setEnabled(grpSingle, false);
            } else if (val === 'tow') {
                grpFromTo.style.display = 'none';
                grpSingle.style.display = '';
                setEnabled(grpFromTo, false);
                setEnabled(grpSingle, true);
            } else {
                grpFromTo.style.display = '';
                grpSingle.style.display = 'none';
                setEnabled(grpFromTo, true);
                setEnabled(grpSingle, false);
            }
        }

        serviceSel.addEventListener('change', applyVisibility);
        applyVisibility();
        window.applyVisibility = applyVisibility;
    })();


    // --- 2. Infinite Scroll + Filtreleme ---
    (function () {
        let currentPage = 1;
        let loading = false;
        let hasMore = true;

        const adsList = document.getElementById("adsList");
        const sentinel = document.getElementById("infiniteSentinel");
        const spinner = document.getElementById("loadingSpinner");
        const form = document.getElementById("filterForm");

        // Scroll sonu mesajı elementi
        let endMessage = document.createElement("div");
        endMessage.className = "text-center text-muted py-3";
        endMessage.style.display = "none";
        endMessage.innerHTML = `<i class="bi bi-check-circle me-2 text-success"></i>Tüm ilanlar yüklendi.`;
        sentinel.insertAdjacentElement("afterend", endMessage);

        function formParams() {
            return form ? new URLSearchParams(new FormData(form)).toString() : "";
        }

        function showSpinner(on) {
            spinner.style.display = on ? "inline-block" : "none";
        }

        function showEndMessage(on) {
            endMessage.style.display = on ? "block" : "none";
        }

        async function fetchPage(page) {
            if (loading || !hasMore) return;
            loading = true;
            showSpinner(true);
            showEndMessage(false);

            const params = formParams();
            const url = `/Home/Index?page=${page}` + (params ? `&${params}` : "");

            const res = await fetch(url, {
                headers: { "X-Requested-With": "XMLHttpRequest" }
            });

            const html = await res.text();
            const cleanHtml = html.trim();

            // --- Eğer hiç ilan yoksa (ilk sayfa) ---
            if (!cleanHtml || cleanHtml.includes("Kriterlere uygun ilan bulunamadı")) {
                if (page === 1) {
                    adsList.innerHTML = `
                        <div class="text-center text-muted py-5" style="min-height:200px;">
                            <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
                            <span>Kriterlere uygun ilan bulunamadı.</span>
                        </div>`;
                } else {
                    showEndMessage(true);
                }
                hasMore = false;
                sentinel.style.display = "none";
                showSpinner(false);
                loading = false;
                return;
            }

            // --- Eğer ilan varsa, listeye ekle ---
            adsList.insertAdjacentHTML("beforeend", cleanHtml);
            currentPage++;
            showSpinner(false);
            loading = false;
        }

        // Scroll izleme
        const observer = new IntersectionObserver(async entries => {
            for (const entry of entries) {
                if (entry.isIntersecting && hasMore && !loading) {
                    await fetchPage(currentPage + 1);
                }
            }
        }, { rootMargin: "0px 0px 200px 0px" });

        observer.observe(sentinel);

        // Filtre gönderilince listeyi sıfırla
        form?.addEventListener("submit", async function (e) {
            e.preventDefault();
            adsList.innerHTML = "";
            currentPage = 1;
            hasMore = true;
            sentinel.style.display = "";
            showEndMessage(false);
            await fetchPage(1);
            document.getElementById("adsList").scrollIntoView({ behavior: "smooth" });
        });

        // Filtre sıfırlama
        document.getElementById("btnResetFilters")?.addEventListener("click", async (e) => {
            e.preventDefault();
            form.reset();
            applyVisibility?.();
            adsList.innerHTML = "";
            currentPage = 1;
            hasMore = true;
            sentinel.style.display = "";
            showEndMessage(false);
            await fetchPage(1);
            document.getElementById("adsList").scrollIntoView({ behavior: "smooth" });
        });
    })();
</script>







