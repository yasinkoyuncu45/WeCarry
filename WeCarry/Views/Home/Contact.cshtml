@model WeCarry.Models.ContactFormDto
@{
    ViewData["Title"] = "İletişim";
    Layout = "~/Views/Shared/DefaultLayout.cshtml";
}

<main class="flex-shrink-0">
    <section class="py-5">
        <div class="container px-5">

            <!-- Başlık -->
            <div class="text-center mb-5">
                <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3">
                    <i class="bi bi-envelope"></i>
                </div>
                <h1 class="fw-bolder">Bize Ulaşın</h1>
                <p class="lead fw-normal text-muted mb-0">
                    Görüş ve önerileriniz bizim için çok değerli.
                </p>
            </div>

            <!-- Başarı / Hata mesajları -->
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-@TempData["MessageType"] mt-3 text-center">
                    @TempData["Message"]
                </div>
            }

            <!-- Form -->
            <div class="row gx-5 justify-content-center">
                <div class="col-lg-8 col-xl-6">
                    <!-- ✅ Controller yolunu net belirtelim -->
                    <form asp-controller="Home" asp-action="Contact" method="post">
                        @Html.AntiForgeryToken()

                        <!-- Ad Soyad -->
                        <div class="form-floating mb-3">
                            <input asp-for="Name" class="form-control" placeholder="Adınızı giriniz" />
                            <label asp-for="Name"></label>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <!-- E-posta -->
                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control" placeholder="E-posta adresiniz" />
                            <label asp-for="Email"></label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- Telefon -->
                        <div class="form-floating mb-3">
                            <input asp-for="Phone" class="form-control" placeholder="05xx xxx xx xx" />
                            <label asp-for="Phone"></label>
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <!-- Mesaj -->
                        <div class="form-floating mb-3">
                            <textarea asp-for="Message" class="form-control" style="height: 10rem" placeholder="Mesajınız"></textarea>
                            <label asp-for="Message"></label>
                            <span asp-validation-for="Message" class="text-danger small"></span>
                        </div>

                        <!-- Gönder Butonu -->
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-send me-2"></i> Gönder
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- İletişim Bilgileri -->
            <div class="row gx-5 row-cols-1 row-cols-md-2 py-5 text-center">
                <div class="col mb-4">
                    <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3 d-inline-flex align-items-center justify-content-center p-3">
                        <i class="bi bi-telephone fs-3"></i>
                    </div>
                    <h5 class="fw-bolder">Telefon</h5>
                    <p class="text-muted mb-0">+90 (538) 811 45 04</p>
                </div>
                <div class="col mb-4">
                    <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3 d-inline-flex align-items-center justify-content-center p-3">
                        <i class="bi bi-envelope-open fs-3"></i>
                    </div>
                    <h5 class="fw-bolder">E-posta</h5>
                    <p class="text-muted mb-0">info@tasiyicin.com</p>
                </div>
            </div>
        </div>
    </section>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
