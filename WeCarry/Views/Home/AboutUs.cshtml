@{
    ViewData["Title"] = "Hakkımızda";
    Layout = "~/Views/Shared/DefaultLayout.cshtml";
}

<main class="flex-shrink-0">
    <!-- Header -->
    <header class="py-5">
        <div class="container px-5">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-xxl-6">
                    <div class="text-center my-5">
                        <h1 class="fw-bolder mb-3">Yükleriniz Yolda Kalmasın, Taşıyıcın Yanınızda!</h1>
                        <p class="lead fw-normal text-muted mb-4">
                            Taşıyıcın, yük sahiplerini tır ve çekici sürücüleriyle buluşturan
                            modern bir dijital platformdur. Amacımız; taşımacılığı daha hızlı,
                            güvenli ve şeffaf hale getirmek.
                        </p>
                        <a class="btn btn-primary btn-lg" href="#hikaye">Hikayemiz</a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Kuruluşumuz -->
    <section class="py-5 bg-light" id="hikaye">
        <div class="container px-5 my-5">
            <div class="row gx-5 align-items-center">
                <div class="col-lg-6">
                    <img class="img-fluid rounded mb-5 mb-lg-0 shadow" src="~/Resimler/kurulus.jpg" alt="Taşıyıcın Kuruluşumuz" />
                </div>
                <div class="col-lg-6">
                    <h2 class="fw-bolder">Kuruluşumuz</h2>
                    <p class="lead fw-normal text-muted mb-0">
                        Lojistikte iletişim ve güven problemlerini çözmek için yola çıktık.
                        Yük sahipleri ile taşıyıcıları tek bir platformda buluşturarak
                        süreci daha ekonomik ve erişilebilir hale getirdik.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Misyon & Vizyon -->
    <section class="py-5">
        <div class="container px-5 my-5">
            <div class="row gx-5 align-items-center">
                <div class="col-lg-6 order-first order-lg-last">
                    <img class="img-fluid rounded mb-5 mb-lg-0 shadow" src="~/Resimler/misyon-vizyon.jpg" alt="Misyon ve Vizyon" />
                </div>
                <div class="col-lg-6">
                    <div class="mb-4">
                        <h2 class="fw-bolder">Misyonumuz</h2>
                        <p class="lead fw-normal text-muted mb-0">
                            Lojistik süreçlerini dijitalleştirerek yük sahipleri ile
                            taşıyıcıları hızlı, güvenli ve şeffaf bir şekilde
                            buluşturmak; taşımacılığı kolay ve güvenilir kılmak.
                        </p>
                    </div>
                    <div>
                        <h2 class="fw-bolder">Vizyonumuz</h2>
                        <p class="lead fw-normal text-muted mb-0">
                            Türkiye’nin en güvenilir taşıma platformu olmak ve
                            global pazarlarda lider dijital lojistik çözümleri sunmak.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Büyüme ve Gelecek -->
    <section class="py-5 bg-light">
        <div class="container px-5 my-5">
            <div class="row gx-5 align-items-center">
                <div class="col-lg-6">
                    <img class="img-fluid rounded mb-5 mb-lg-0 shadow" src="~/Resimler/gelecek.jpg" alt="Büyüme ve Gelecek" />
                </div>
                <div class="col-lg-6">
                    <h2 class="fw-bolder">Büyüme ve Gelecek</h2>
                    <p class="lead fw-normal text-muted mb-0">
                        Her gün daha fazla kullanıcıyı doğru taşıyıcılarla buluşturuyoruz.
                        Yol haritamızda; yeni şehirler, gelişmiş eşleştirme algoritmaları ve
                        iş ortaklıklarıyla değer katmaya devam etmek var.
                    </p>
                </div>
            </div>
        </div>
    </section>
</main>
