@model IEnumerable<WeCarry.Models.MVVM.Ads>

@if (Model != null && Model.Any())
{
    @foreach (var item in Model)
    {
        <div class="card ad-card mb-4 shadow-sm">

            <!-- Firma Adı (Kart Başlığı) -->
            <div class="card-header bg-light fw-bold text-primary border-bottom">
                <i class="bi bi-building me-1"></i> @(item.User?.Firm ?? "Bilinmeyen Firma")
            </div>

            <!-- Üst Rozetler -->
            <div class="ad-top px-3 pt-3">
                <div class="ad-badges">
                    <span class="badge rounded-pill badge-service @(item.ServiceTypeID == 2 ? "tow" : "truck")">
                        @if (item.ServiceTypeID == 1)
                        {
                            <i class="bi bi-truck me-1">Tır Hizmeti</i>
                            
                                        }
                        else if (item.ServiceTypeID == 2)
                        {
                            <i class="bi bi-truck-flatbed me-1"> Çekici Hizmeti</i>
                           
                                }
                    </span>

                    <span class="badge rounded-pill badge-fee">@item.KmFee TL/km</span>
                </div>
            </div>

            <!-- Güzergâh -->
            <div class="ad-route fw-bold text-primary px-3 mt-2">
                @item.FoundCity → @item.DestinationCity
            </div>

            <!-- Açıklama -->
            @if (!string.IsNullOrWhiteSpace(item.AdvertisementText))
            {
                <div class="ad-desc text-muted px-3 mt-2">@item.AdvertisementText</div>
            }

            <!-- Alt Bar -->
            <div class="ad-footer d-flex justify-content-between align-items-center mt-3 border-top px-3 py-2">
                <div class="date small text-secondary">
                    <i class="bi bi-clock"></i> @item.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                </div>
                <a asp-controller="Chat"
                   asp-action="WithAd"
                   asp-route-adId="@item.AdsID"
                   class="btn btn-sm btn-outline-primary">
                    İletişime Geç <i class="bi bi-arrow-right-short"></i>
                </a>
            </div>
        </div>
    }
}
else
{
    <!-- Boş sonuç mesajı -->
    <div class="text-center text-muted py-5" style="min-height:200px;">
        <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
        <span>Kriterlere uygun ilan bulunamadı.</span>
    </div>
}
