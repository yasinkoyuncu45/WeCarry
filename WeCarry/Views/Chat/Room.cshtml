@model WeCarry.Models.MVVM.ChatRoomViewModel
@{
    Layout = "~/Views/Shared/DefaultLayout.cshtml";
    var me = Context.Session.GetInt32("UserId");
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Sohbet</h5>

        @* Sohbet aktifse sonlandır butonu sağ üstte *@
        @if (!Model.IsEnded)
        {
            <form asp-action="End" asp-controller="Chat" method="post" class="ms-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.ConversationID" />
                <button type="submit" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-x-circle"></i> Sohbeti Sonlandır
                </button>
            </form>
        }
    </div>

    <div id="chatMessages" class="border rounded p-3 mb-3" style="height:400px; overflow-y:auto;">
        @foreach (var m in Model.Messages.OrderBy(x => x.CreatedAt))
        {
            <div class="mb-2 @(m.SenderUserID == me ? "text-end" : "text-start")">
                <div>
                    <strong>@(m.SenderUserID == me ? "Ben" : m.SenderName)</strong>
                </div>
                <span class="badge @(m.SenderUserID == me ? "bg-primary" : "bg-secondary")">
                    @m.Body
                </span>
                <div class="small text-muted">@m.CreatedAt.ToLocalTime()</div>
            </div>
        }

    </div>

    @if (!Model.IsEnded)
    {
        <form id="chatForm" class="d-flex">
            <input type="text" id="chatInput" class="form-control me-2" placeholder="Mesaj yazın..." autocomplete="off" />
            <button type="submit" class="btn btn-primary">Gönder</button>
        </form>
    }
    else
    {
        <div class="alert alert-warning">Bu sohbet sonlandırılmış.</div>
    }

    <div id="typing" class="small text-muted mt-2" style="display:none;">Karşı taraf yazıyor...</div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const conversationId = @Model.ConversationID;
        const meUserId = @me;

        // Güvenli ekleme: XSS'e karşı metni textContent ile basacağız.
            function appendMessage({ senderUserId, senderName, body, createdAt }) {
        const wrap = document.createElement("div");
        wrap.className = "mb-2 " + (senderUserId == meUserId ? "text-end" : "text-start");

        const nameDiv = document.createElement("div");
        nameDiv.innerHTML = "<strong>" + (senderUserId == meUserId ? "Ben" : senderName) + "</strong>";

        const badge = document.createElement("span");
        badge.className = "badge " + (senderUserId == meUserId ? "bg-primary" : "bg-secondary");
        badge.textContent = body;

        const meta = document.createElement("div");
        meta.className = "small text-muted";
        meta.textContent = new Date(createdAt).toLocaleString();

        wrap.appendChild(nameDiv);
        wrap.appendChild(badge);
        wrap.appendChild(meta);

        const list = document.getElementById("chatMessages");
        list.appendChild(wrap);
        list.scrollTop = list.scrollHeight;
        }

        // SignalR bağlantısı
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/chat")
            .build();

        connection.start().then(() => {
            connection.invoke("JoinConversation", conversationId);
            markRead();
        }).catch(err => console.error(err));

        // Mesaj al
            connection.on("ReceiveMessage", (msg) => {
        if (!msg || msg.conversationId != conversationId) return;
        appendMessage({
            senderUserId: msg.senderUserId,
            senderName: msg.senderName,   // ✅ artık bu da geliyor
            body: msg.body,
            createdAt: msg.createdAt
            });
        });

        // Yazıyor bildirimi
        connection.on("UserTyping", (info) => {
            if (info && info.conversationId == conversationId) {
                const typingDiv = document.getElementById("typing");
                typingDiv.style.display = "block";
                setTimeout(() => typingDiv.style.display = "none", 1500);
            }
        });

        // Mesaj gönder
        document.getElementById("chatForm")?.addEventListener("submit", function (e) {
            e.preventDefault();
            const input = document.getElementById("chatInput");
            const val = (input.value || "").trim();
            if (!val) return;

            connection.invoke("SendMessage", conversationId, meUserId, val)
                .catch(err => console.error(err));
            input.value = "";
        });

        // Enter ile gönderme (mobil uyumu iyi)
        document.getElementById("chatInput")?.addEventListener("keydown", function (e) {
            if (e.key === "Enter" && !e.shiftKey) {
                e.preventDefault();
                document.getElementById("chatForm")?.dispatchEvent(new Event("submit"));
            }
        });

        // Yazıyor olayı
        document.getElementById("chatInput")?.addEventListener("input", function () {
            connection.invoke("Typing", conversationId, meUserId).catch(()=>{});
        });

        // Okundu işaretle (sayfa açıldığında)
        function markRead() {
            fetch(`/Chat/MarkRead?conversationId=${conversationId}`, { method: "POST", credentials: "same-origin" })
                .catch(()=>{});
        }
    </script>
}
