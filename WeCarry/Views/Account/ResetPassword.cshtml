@model WeCarry.Models.MVVM.ResetPasswordViewModel

@{
    ViewData["Title"] = "Şifreyi Sıfırla";
    Layout = "~/Views/Shared/DefaultLayout.cshtml";
}

<section class="py-5">
    <div class="container px-5">
        <div class="bg-light rounded-3 py-5 px-4 px-md-5 mb-5">
            <div class="text-center mb-4">
                <h1 class="fw-bolder">Yeni Şifre Belirle</h1>
                <p class="text-muted">Güçlü ve unutmayacağınız bir şifre giriniz.</p>
            </div>

            @* Hata veya bilgi mesajı *@
            @if (ViewData["Message"] != null)
            {
                <div class="alert alert-info text-center">
                    @ViewData["Message"]
                </div>
            }

            <div class="row gx-5 justify-content-center">
                <div class="col-lg-8 col-xl-6">

                    <!-- ✅ Controller yönlendirmesi Account olarak değiştirildi -->
                    <form asp-controller="Account" asp-action="ResetPassword" method="post" novalidate>
                        @Html.AntiForgeryToken()

                        <!-- Token ve Email gizli alanlarda gönderilir -->
                        <input type="hidden" asp-for="Token" />
                        <input type="hidden" asp-for="Email" />

                        <div class="form-floating mb-3">
                            <input asp-for="NewPassword" class="form-control" type="password" placeholder="Yeni şifre" />
                            <label asp-for="NewPassword">Yeni Şifre</label>
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Yeni şifre (tekrar)" />
                            <label asp-for="ConfirmPassword">Yeni Şifre (Tekrar)</label>
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid mb-3">
                            <button class="btn btn-primary btn-lg" type="submit">
                                <i class="bi bi-check2-circle me-1"></i> Şifreyi Güncelle
                            </button>
                        </div>

                        <div class="text-center">
                            <a asp-controller="Account" asp-action="Login" class="text-decoration-none">
                                <i class="bi bi-arrow-left"></i> Giriş sayfasına dön
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
