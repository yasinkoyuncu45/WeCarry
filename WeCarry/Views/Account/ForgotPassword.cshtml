@model WeCarry.Models.MVVM.MainPageModel

@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout = "~/Views/Shared/DefaultLayout.cshtml";
}

<section class="py-5">
    <div class="container px-5">
        <div class="bg-light rounded-3 py-5 px-4 px-md-5 mb-5">
            <div class="text-center mb-4">
                <h1 class="fw-bolder">Şifremi Unuttum</h1>
                <p class="text-muted">
                    Kayıtlı e-posta adresinizi girin. Şifre sıfırlama bağlantısı size gönderilecektir.
                </p>
            </div>

            @* Mail gönderimi sonrası bilgi mesajı *@
            @if (ViewData["Message"] != null)
            {
                <div class="alert alert-info text-center">
                    @ViewData["Message"]
                </div>
            }

            <div class="row gx-5 justify-content-center">
                <div class="col-lg-8 col-xl-6">
                    <!-- ✅ Controller artık Account -->
                    <form asp-controller="Account" asp-action="ForgotPassword" method="post" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="form-floating mb-3">
                            <input class="form-control" asp-for="ForgotPasswordEmail" placeholder="name@example.com" />
                            <label asp-for="ForgotPasswordEmail">E-posta Adresi</label>
                            <span asp-validation-for="ForgotPasswordEmail" class="text-danger"></span>
                        </div>

                        <div class="d-grid mb-3">
                            <button class="btn btn-primary btn-lg" type="submit">
                                <i class="bi bi-envelope-check me-1"></i> Şifre Sıfırlama Bağlantısı Gönder
                            </button>
                        </div>

                        <div class="text-center">
                            <!-- ✅ Login yönlendirmesi de Account üzerinden -->
                            <a asp-controller="Account" asp-action="Login" class="text-decoration-none">
                                <i class="bi bi-arrow-left"></i> Giriş sayfasına dön
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
