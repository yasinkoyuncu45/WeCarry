@model WeCarry.Models.MVVM.User
@{
    ViewData["Title"] = "Profili Düzenle";
    Layout = "~/Views/Shared/DefaultLayout.cshtml";
}

<div class="container my-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white fw-bold">Profilimi Düzenle</div>
        <div class="card-body">
            <!-- ✅ Controller ve Action düzeltildi -->
            <form asp-controller="Account" asp-action="EditProfile" method="post" autocomplete="off">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.UserID" />

                <!-- Dummy inputlar (tarayıcıyı kandırmak için) -->
                <input type="text" style="display:none" autocomplete="username" />
                <input type="password" style="display:none" autocomplete="new-password" />

                <!-- Hata Mesajları -->
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <!-- Sadece okunabilir alanlar -->
                <div class="mb-3">
                    <label class="form-label">Ad</label>
                    <input class="form-control" value="@Model.Name" readonly />
                </div>
                <div class="mb-3">
                    <label class="form-label">Soyad</label>
                    <input class="form-control" value="@Model.Surname" readonly />
                </div>
                <div class="mb-3">
                    <label class="form-label">E-posta</label>
                    <input class="form-control" value="@Model.Email" readonly />
                </div>
                <div class="mb-3">
                    <label class="form-label">Adres</label>
                    <input class="form-control" value="@Model.Address" readonly />
                </div>

                <!-- Düzenlenebilir alanlar -->
                <div class="mb-3">
                    <label class="form-label">Firma</label>
                    <input type="text" name="Firm" value="@Model.Firm" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Telefon</label>
                    <input type="tel" name="Telephone" value="@Model.Telephone" class="form-control" required />
                </div>

                <!-- Şifre alanları -->
                <div class="mb-3">
                    <label class="form-label">Eski Şifre</label>
                    <input type="password" name="CurrentPass" class="form-control" autocomplete="off" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Yeni Şifre</label>
                    <input type="password" name="NewPass" class="form-control" autocomplete="off" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Yeni Şifre (Tekrar)</label>
                    <input type="password" name="ConfirmPass" class="form-control" autocomplete="off" />
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> Kaydet
                </button>

                <!-- ✅ Controller yönlendirmesi düzeltildi -->
                <a asp-controller="Account" asp-action="Profile" class="btn btn-secondary ms-2">İptal</a>
            </form>
        </div>
    </div>
</div>
