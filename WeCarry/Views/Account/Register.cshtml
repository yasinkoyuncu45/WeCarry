@using WeCarry.Models.MVVM
@model User
@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = "~/Views/Shared/DefaultLayout.cshtml";
}

<section class="py-5">
    <div class="container px-5">
        <div class="bg-light rounded-3 py-5 px-4 px-md-5 mb-5">
            <div class="text-center mb-5">
                <h1 class="fw-bolder">Kayıt Ol</h1>
            </div>

            <div class="row gx-5 justify-content-center">
                <div class="col-lg-8 col-xl-6">

                    <!-- ✅ Controller yönlendirmesi düzeltildi -->
                    <form asp-controller="Account" asp-action="Register" method="post">

                        <div class="form-floating mb-3">
                            <input class="form-control" asp-for="Name" placeholder="Adınız..." />
                            <label asp-for="Name">Adınız</label>
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input class="form-control" asp-for="Surname" placeholder="Soyadınız..." />
                            <label asp-for="Surname">Soyadınız</label>
                            <span asp-validation-for="Surname" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input class="form-control" asp-for="Email" placeholder="name@example.com" />
                            <label asp-for="Email">Email</label>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input class="form-control" asp-for="Password" type="password" placeholder="Şifreniz..." />
                            <label asp-for="Password">Şifre</label>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input class="form-control" asp-for="Telephone" placeholder="(123) 456-7890" />
                            <label asp-for="Telephone">Telefon</label>
                            <span asp-validation-for="Telephone" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input class="form-control" asp-for="Address" placeholder="Adres..." />
                            <label asp-for="Address">Adres</label>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <!-- Normal kullanıcı için sabit servis tipi -->
                        <input type="hidden" name="ServiceTypeID" value="3" />

                        <div class="d-grid">
                            <button class="btn btn-primary btn-lg" type="submit">
                                <i class="bi bi-person-plus me-1"></i> Kayıt Ol
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
