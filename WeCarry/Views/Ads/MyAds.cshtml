@model IEnumerable<WeCarry.Models.MVVM.Ads>
@{
    ViewData["Title"] = "İlanlarım";
    Layout = "~/Views/Shared/DefaultLayout.cshtml";
}

<div class="container my-5">
    <h2 class="mb-4">İlanlarım</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center">
            Henüz hiç ilanınız bulunmamaktadır.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Hizmet</th>
                        <th>Çıkış</th>
                        <th>Varış</th>
                        <th>Ücret</th>
                        <th>Açıklama</th>
                        <th>Durum</th>
                        <th>Tarih</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ad in Model)
                    {
                        <tr>
                            <input type="hidden" value="@ad.AdsID" />
                            <td>@ad.ServiceType?.Name</td>
                            <td>@ad.FoundCity</td>
                            <td>@ad.DestinationCity</td>
                            <td>@ad.KmFee.ToString("0.00") TL/km</td>
                            <td>@(string.IsNullOrEmpty(ad.AdvertisementText) ? "-" : ad.AdvertisementText)</td>
                            <td>
                                <span class="badge @(ad.IsActive ? "bg-success" : "bg-secondary")">
                                    @(ad.IsActive ? "Aktif" : "Pasif")
                                </span>
                            </td>
                            <td>@ad.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td>
                              
                                <a asp-controller="Ads" asp-action="EditAd" asp-route-id="@ad.AdsID"
                                   class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Düzenle
                                </a>

                                <a asp-controller="Ads" asp-action="DeleteAd" asp-route-id="@ad.AdsID"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('Bu ilanı kaldırmak istediğinize emin misiniz?');">
                                    <i class="bi bi-trash"></i> Kaldır
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
